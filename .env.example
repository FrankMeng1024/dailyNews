# AI News App Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Required API Keys
# ===========================================

# Zhipu GLM API Key (from open.bigmodel.cn)
GLM_API_KEY=your_glm_api_key_here

# NewsAPI Key (from newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# WeChat Mini Program (from WeChat MP Console)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ===========================================
# Security (Change in Production!)
# ===========================================

# JWT Secret Key - CHANGE THIS!
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# ===========================================
# Optional Configuration
# ===========================================

# Database (defaults work with docker-compose)
# DATABASE_URL=mysql+pymysql://ainews:ainews123@db:3306/ainews

# Timezone
# TIMEZONE=Asia/Shanghai

# Debug mode
# DEBUG=false
