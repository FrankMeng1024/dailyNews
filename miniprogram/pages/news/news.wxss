/* News Page Styles */

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}

.dark .header {
  background: #000000;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.header-action {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 50%;
}

.dark .header-action {
  background: rgba(10, 132, 255, 0.2);
}

/* Fetch Progress Banner */
.fetch-progress {
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  padding: 20rpx 32rpx;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx;
}

.dark .fetch-progress {
  background: linear-gradient(135deg, #0A84FF 0%, #5E5CE6 100%);
}

.progress-content {
  display: flex;
  align-items: center;
}

.progress-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.progress-text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
}

/* News List */
.news-list {
  height: calc(100vh - 180rpx);
}

/* News Card */
.news-card {
  display: flex;
  background: #FFFFFF;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .news-card {
  background: #1C1C1E;
  box-shadow: none;
}

.news-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.news-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.news-source {
  font-size: 24rpx;
  color: #007AFF;
  font-weight: 500;
}

.dark .news-source {
  color: #0A84FF;
}

.news-time {
  font-size: 22rpx;
  color: #86868B;
  margin-left: 16rpx;
}

.dark .news-time {
  color: #98989D;
}

.news-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.news-footer {
  display: flex;
  align-items: center;
  margin-top: auto;
}

.importance-badge {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.news-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* Loading & Empty */
.loading, .no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  color: #86868B;
  margin-bottom: 8rpx;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 90vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
}

.dark .modal-content {
  background: #1C1C1E;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: flex-end;
  padding: 24rpx;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
}

.dark .modal-close {
  background: rgba(255, 255, 255, 0.1);
}

.modal-body {
  max-height: calc(90vh - 112rpx);
  padding: 0 32rpx 48rpx;
}

/* Detail Content */
.detail-image {
  width: 100%;
  height: 360rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.detail-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.detail-source {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}

.dark .detail-source {
  color: #0A84FF;
}

.detail-time {
  font-size: 24rpx;
  color: #86868B;
  margin-left: 16rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.detail-author {
  margin-bottom: 24rpx;
}

.detail-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #3D3D3D;
  margin-bottom: 32rpx;
}

.dark .detail-content {
  color: #D1D1D6;
}

.detail-actions {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
