<view class="container {{theme}}">
  <!-- Header -->
  <view class="header">
    <text class="header-title">AI News</text>
    <view class="header-action" bindtap="onManualFetch">
      <text wx:if="{{fetchStatus}}" class="status-text">{{fetchStatus}}</text>
      <image
        wx:else
        src="/images/icons/refresh.png"
        class="icon"
        mode="aspectFit"
      />
    </view>
  </view>

  <!-- News List -->
  <scroll-view
    scroll-y
    class="news-list"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <!-- News Cards -->
    <view
      wx:for="{{newsList}}"
      wx:key="id"
      class="news-card"
      bindtap="onNewsClick"
      data-id="{{item.id}}"
    >
      <view class="news-content">
        <view class="news-header">
          <text class="news-source">{{item.source_name}}</text>
          <text class="news-time">{{item.relativeTime}}</text>
        </view>
        <text class="news-title">{{item.title}}</text>
        <view class="news-footer">
          <view
            class="importance-badge"
            style="background: {{item.importanceColor}}20; color: {{item.importanceColor}}"
          >
            {{item.importanceLabel}}
          </view>
        </view>
      </view>
      <image
        wx:if="{{item.image_url}}"
        src="{{item.image_url}}"
        class="news-image"
        mode="aspectFill"
      />
    </view>

    <!-- Loading -->
    <view wx:if="{{loading && newsList.length > 0}}" class="loading">
      <text>Loading more...</text>
    </view>

    <!-- No more -->
    <view wx:if="{{!hasMore && newsList.length > 0}}" class="no-more">
      <text class="caption">No more news</text>
    </view>

    <!-- Empty state -->
    <view wx:if="{{!loading && newsList.length === 0}}" class="empty">
      <image src="/images/icons/news.png" class="empty-icon" mode="aspectFit"/>
      <text class="empty-text">No news yet</text>
      <text class="empty-text caption">Tap refresh to fetch latest AI news</text>
    </view>
  </scroll-view>

  <!-- News Detail Modal -->
  <view wx:if="{{showDetail}}" class="modal-overlay" bindtap="onDetailClose">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <view class="modal-close" bindtap="onDetailClose">
          <image src="/images/icons/close.png" class="icon" mode="aspectFit"/>
        </view>
      </view>

      <scroll-view scroll-y class="modal-body">
        <image
          wx:if="{{selectedNews.image_url}}"
          src="{{selectedNews.image_url}}"
          class="detail-image"
          mode="aspectFill"
        />

        <view class="detail-meta">
          <text class="detail-source">{{selectedNews.source_name}}</text>
          <text class="detail-time">{{selectedNews.relativeTime}}</text>
        </view>

        <text class="detail-title">{{selectedNews.title}}</text>

        <!-- Tab Bar - Below Title -->
        <view class="tab-bar">
          <view
            class="tab-item {{activeTab === 'original' ? 'active' : ''}}"
            bindtap="onToggleContent"
            data-type="original"
          >
            <text class="tab-text">原文</text>
            <view class="tab-indicator" wx:if="{{activeTab === 'original'}}"></view>
          </view>
          <view
            class="tab-item {{activeTab === 'summary' ? 'active' : ''}}"
            bindtap="onToggleContent"
            data-type="summary"
          >
            <text class="tab-text">
              {{selectedNews.content_status === 'generating' ? '生成中...' : '精炼'}}
            </text>
            <view class="tab-indicator" wx:if="{{activeTab === 'summary'}}"></view>
          </view>
        </view>

        <view class="detail-content">
          <!-- 原文标签页 -->
          <block wx:if="{{activeTab === 'original'}}">
            <text wx:if="{{selectedNews.original_content}}" class="content-text">{{selectedNews.original_content}}</text>
            <view wx:else class="no-original">
              <text class="no-original-text">暂无原文内容</text>
              <text class="no-original-hint">点击下方按钮查看原文</text>
            </view>
          </block>
          <!-- 精炼标签页 -->
          <block wx:else>
            <!-- 精炼内容已就绪 -->
            <text wx:if="{{selectedNews.content_status === 'ready' && selectedNews.content}}" class="content-text">{{selectedNews.content}}</text>
            <!-- 精炼内容生成中 -->
            <view wx:elif="{{selectedNews.content_status === 'generating'}}" class="content-loading">
              <view class="loading-spinner"></view>
              <text class="loading-text">AI 正在生成摘要...</text>
            </view>
            <!-- 精炼内容待生成 -->
            <view wx:elif="{{selectedNews.content_status === 'pending'}}" class="content-loading">
              <view class="loading-spinner"></view>
              <text class="loading-text">摘要生成中，请稍候...</text>
            </view>
            <!-- 无内容时显示提示 -->
            <text wx:else class="content-text">{{selectedNews.content || selectedNews.summary || '暂无摘要内容'}}</text>
          </block>
        </view>

        <!-- Open Source Button -->
        <view class="source-button" bindtap="onOpenSource">
          <text class="source-button-text">查看原文</text>
          <text class="source-button-icon">→</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
