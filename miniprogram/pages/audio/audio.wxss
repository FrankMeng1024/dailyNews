/* Audio Page Styles */

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
}

.dark .header {
  background: #000000;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
}

/* Audio List */
.audio-list {
  height: calc(100vh - 280rpx);
  padding-bottom: 200rpx;
}

/* Audio Card */
.audio-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .audio-card {
  background: #1C1C1E;
  box-shadow: none;
}

.audio-card.active {
  border: 2rpx solid #007AFF;
}

.dark .audio-card.active {
  border-color: #0A84FF;
}

.audio-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 50%;
  margin-right: 20rpx;
}

.dark .audio-icon {
  background: rgba(10, 132, 255, 0.2);
}

.audio-info {
  flex: 1;
  min-width: 0;
}

.audio-title {
  font-size: 30rpx;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.audio-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.audio-duration, .audio-date {
  font-size: 24rpx;
  color: #86868B;
}

.dark .audio-duration, .dark .audio-date {
  color: #98989D;
}

.status-badge {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.status-badge.processing {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
}

.status-badge.failed {
  background: rgba(255, 59, 48, 0.1);
  color: #FF3B30;
}

.audio-action {
  padding: 16rpx;
  opacity: 0.5;
}

/* FAB */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 112rpx;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #007AFF;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.4);
}

.dark .fab {
  background: #0A84FF;
  box-shadow: 0 8rpx 24rpx rgba(10, 132, 255, 0.4);
}

.fab .icon {
  width: 48rpx;
  height: 48rpx;
}

/* Player */
.player {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.dark .player {
  background: #1C1C1E;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.3);
}

.player-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.player-title {
  font-size: 28rpx;
  font-weight: 600;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-right: 16rpx;
}

.player-time {
  font-size: 24rpx;
  color: #86868B;
}

.player-progress {
  margin: 16rpx 0;
}

.player-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
}

.control-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-btn {
  width: 96rpx;
  height: 96rpx;
  background: #007AFF;
  border-radius: 50%;
}

.dark .play-btn {
  background: #0A84FF;
}

.play-btn .icon-large {
  width: 48rpx;
  height: 48rpx;
}

.speed-btn {
  padding: 12rpx 24rpx;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #007AFF;
}

.dark .speed-btn {
  background: rgba(10, 132, 255, 0.2);
  color: #0A84FF;
}

/* Selector Modal */
.selector-modal {
  height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.dark .modal-header {
  border-bottom-color: #38383A;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selector-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.dark .selector-actions {
  border-bottom-color: #38383A;
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #C7C7CC;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background: #007AFF;
  border-color: #007AFF;
}

.dark .checkbox.checked {
  background: #0A84FF;
  border-color: #0A84FF;
}

.language-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(0, 122, 255, 0.1);
  border-radius: 12rpx;
  color: #007AFF;
  font-size: 26rpx;
}

.dark .language-picker {
  background: rgba(10, 132, 255, 0.2);
  color: #0A84FF;
}

.selector-list {
  flex: 1;
  padding: 16rpx 0;
}

.selector-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 32rpx;
  gap: 16rpx;
}

.selector-item-content {
  flex: 1;
}

.selector-item-title {
  font-size: 28rpx;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.selector-item-source {
  font-size: 24rpx;
  color: #86868B;
}

.selector-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #E5E5EA;
}

.dark .selector-footer {
  border-top-color: #38383A;
}

.btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  animation: slideUp 0.3s ease-out;
}

.dark .modal-content {
  background: #1C1C1E;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* Empty */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  color: #86868B;
  margin-bottom: 8rpx;
}
