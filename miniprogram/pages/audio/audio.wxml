<view class="container {{theme}}">
  <!-- Header -->
  <view class="header">
    <text class="header-title">Audio</text>
  </view>

  <!-- Audio List -->
  <scroll-view scroll-y class="audio-list">
    <view
      wx:for="{{audioList}}"
      wx:key="id"
      class="audio-card {{currentAudio && currentAudio.id === item.id ? 'active' : ''}}"
      bindtap="onAudioClick"
      data-id="{{item.id}}"
    >
      <view class="audio-icon">
        <image
          src="{{currentAudio && currentAudio.id === item.id && isPlaying ? '/images/icons/pause.png' : '/images/icons/play.png'}}"
          class="icon"
          mode="aspectFit"
        />
      </view>
      <view class="audio-info">
        <text class="audio-title">{{item.title}}</text>
        <view class="audio-meta">
          <text class="audio-duration">{{item.durationFormatted}}</text>
          <text class="audio-date">{{item.dateFormatted}}</text>
          <view wx:if="{{item.status === 'processing'}}" class="status-badge processing">
            <text>Generating...</text>
          </view>
          <view wx:elif="{{item.status === 'failed'}}" class="status-badge failed">
            <text>Failed</text>
          </view>
        </view>
      </view>
      <view class="audio-action" catchtap="onDeleteAudio" data-id="{{item.id}}">
        <image src="/images/icons/delete.png" class="icon-small" mode="aspectFit"/>
      </view>
    </view>

    <!-- Empty state -->
    <view wx:if="{{!loading && audioList.length === 0}}" class="empty">
      <image src="/images/icons/audio.png" class="empty-icon" mode="aspectFit"/>
      <text class="empty-text">No audio recordings yet</text>
      <text class="empty-text caption">Tap + to create one from news</text>
    </view>
  </scroll-view>

  <!-- FAB Button -->
  <view class="fab" bindtap="onAddClick">
    <image src="/images/icons/plus.png" class="icon" mode="aspectFit"/>
  </view>

  <!-- Audio Player -->
  <view wx:if="{{showPlayer && currentAudio}}" class="player">
    <view class="player-info">
      <text class="player-title">{{currentAudio.title}}</text>
      <text class="player-time">{{currentTimeFormatted}} / {{durationFormatted}}</text>
    </view>

    <slider
      class="player-progress"
      value="{{progress}}"
      max="100"
      block-size="16"
      activeColor="#007AFF"
      backgroundColor="#E5E5EA"
      bindchange="onSeek"
    />

    <view class="player-controls">
      <view class="control-btn" bindtap="onSkipBackward">
        <image src="/images/icons/backward.png" class="icon" mode="aspectFit"/>
      </view>
      <view class="control-btn play-btn" bindtap="onPlayPause">
        <image
          src="{{isPlaying ? '/images/icons/pause.png' : '/images/icons/play.png'}}"
          class="icon-large"
          mode="aspectFit"
        />
      </view>
      <view class="control-btn" bindtap="onSkipForward">
        <image src="/images/icons/forward.png" class="icon" mode="aspectFit"/>
      </view>
      <view class="speed-btn" bindtap="onSpeedChange">
        <text>{{playbackRate}}x</text>
      </view>
    </view>
  </view>

  <!-- News Selector Modal -->
  <view wx:if="{{showSelector}}" class="modal-overlay" bindtap="onSelectorClose">
    <view class="modal-content selector-modal" catchtap="">
      <view class="modal-header">
        <text class="modal-title">Select News</text>
        <view class="modal-close" bindtap="onSelectorClose">
          <image src="/images/icons/close.png" class="icon" mode="aspectFit"/>
        </view>
      </view>

      <view class="selector-actions">
        <view class="select-all" bindtap="onSelectAll">
          <view class="checkbox {{allSelected ? 'checked' : ''}}">
            <image wx:if="{{allSelected}}" src="/images/icons/check.png" class="icon-small" mode="aspectFit"/>
          </view>
          <text>Select All</text>
        </view>
        <picker mode="selector" range="{{languageOptions}}" range-key="label" bindchange="onLanguageSelect">
          <view class="language-picker">
            <text>{{selectedLanguage.label}}</text>
            <image src="/images/icons/chevron-down.png" class="icon-small" mode="aspectFit"/>
          </view>
        </picker>
      </view>

      <scroll-view scroll-y class="selector-list">
        <view
          wx:for="{{availableNews}}"
          wx:key="id"
          class="selector-item"
          bindtap="onNewsSelect"
          data-id="{{item.id}}"
        >
          <view class="checkbox {{selectedNewsIds.includes(item.id) ? 'checked' : ''}}">
            <image wx:if="{{selectedNewsIds.includes(item.id)}}" src="/images/icons/check.png" class="icon-small" mode="aspectFit"/>
          </view>
          <view class="selector-item-content">
            <text class="selector-item-title">{{item.title}}</text>
            <text class="selector-item-source">{{item.source_name}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="selector-footer">
        <view
          class="btn btn-primary {{selectedNewsIds.length === 0 ? 'disabled' : ''}}"
          bindtap="onCreateAudio"
        >
          <text>Generate Audio ({{selectedNewsIds.length}} selected)</text>
        </view>
      </view>
    </view>
  </view>
</view>
