/* Global Styles - Apple-like Minimalist Design */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: #1D1D1F;
  background-color: #F5F5F7;
}

/* Dark mode */
.dark {
  color: #FFFFFF;
  background-color: #000000;
}

.dark page {
  background-color: #000000;
}

/* Container */
.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* Cards */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.dark .card {
  background: #1C1C1E;
  box-shadow: none;
}

/* Typography */
.title-large {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
}

.subtitle {
  font-size: 28rpx;
  color: #86868B;
}

.dark .subtitle {
  color: #98989D;
}

.body {
  font-size: 28rpx;
  line-height: 1.6;
}

.caption {
  font-size: 24rpx;
  color: #86868B;
}

.dark .caption {
  color: #98989D;
}

/* Buttons */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary {
  background: #007AFF;
  color: #FFFFFF;
}

.dark .btn-primary {
  background: #0A84FF;
}

.btn-secondary {
  background: rgba(0, 122, 255, 0.1);
  color: #007AFF;
}

.dark .btn-secondary {
  background: rgba(10, 132, 255, 0.2);
  color: #0A84FF;
}

/* Icons */
.icon {
  width: 44rpx;
  height: 44rpx;
}

.icon-small {
  width: 32rpx;
  height: 32rpx;
}

.icon-large {
  width: 56rpx;
  height: 56rpx;
}

/* Badges */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-hot {
  background: rgba(255, 59, 48, 0.1);
  color: #FF3B30;
}

.badge-important {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
}

.badge-normal {
  background: rgba(52, 199, 89, 0.1);
  color: #34C759;
}

/* Loading */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #86868B;
}

/* Empty state */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #86868B;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  text-align: center;
}

/* Divider */
.divider {
  height: 1rpx;
  background: #E5E5EA;
  margin: 24rpx 0;
}

.dark .divider {
  background: #38383A;
}

/* Safe area */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* Animations */
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.rotating {
  animation: rotate 1s linear infinite;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* Flex utilities */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* Spacing */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-16 { margin-left: 16rpx; }
.mr-16 { margin-right: 16rpx; }
